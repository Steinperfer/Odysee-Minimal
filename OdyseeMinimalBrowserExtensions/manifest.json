{
  "manifest_version": 3,
  "name": "Odysee Minimal",
  "version": "1.0",
  "description": "Odysee minimal YouTube Style",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "*://odysee.com/*",
        "*://*.odysee.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
