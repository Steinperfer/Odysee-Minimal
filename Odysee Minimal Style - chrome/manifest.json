{
  "manifest_version": 3,
  "name": "Odysee Minimal Youtube Style",
  "description": "Minimalistisches YouTube-ähnliches Layout für Odysee",
  "version": "4.1",

  "content_scripts": [
    {
      "matches": ["https://odysee.com/*"],
      "js": ["content.js", "odyseeresize.js"],
      "run_at": "document_idle"
    }
  ]
}